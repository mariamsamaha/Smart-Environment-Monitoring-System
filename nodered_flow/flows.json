    {
        "id": "fn_watchdog",
        "type": "function",
        "z": "flow1",
        "name": "Watchdog Check",
        "func": "var last = global.get('last_heartbeat') || 0;\nvar diff = Date.now() - last;\nif (last === 0) {\n    msg.payload = 'Waiting for ESP32...';\n} else if (diff > 30000) {\n    msg.payload = 'ESP32 OFFLINE â€” No heartbeat for ' + Math.round(diff/1000) + 's';\n} else {\n    msg.payload = 'ESP32 Online â€” Last seen ' + Math.round(diff/1000) + 's ago';\n}\nreturn msg;",
        "outputs": 1,
        "x": 320,
