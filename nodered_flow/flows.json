        "z": "da2297979f2a7d69",
        "name": "Build CSV String",
        "func": "var log = global.get('sensor_log') || [];\nvar csv = 'timestamp,temperature,humidity,light,motion,distance\\n';\nlog.forEach(function(r){\n    csv += [r.time, r.temp, r.hum, r.light, r.motion, r.dist].join(',') + '\\n';\n});\nmsg.payload  = csv;\nmsg.filename = '/tmp/sensor_export.csv';\nreturn msg;",
