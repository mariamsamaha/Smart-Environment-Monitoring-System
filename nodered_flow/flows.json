    {
        "id": "fn_log",
        "type": "function",
        "z": "flow1",
        "name": "Append Log",
        "func": "var log = global.get('sensor_log') || [];\nvar isNew = log.length === 0;\nvar entry = {\n    ts:     Date.now(),\n    time:   new Date().toISOString(),\n    temp:   global.get('last_temp')   || 0,\n    hum:    global.get('last_hum')    || 0,\n    light:  global.get('last_light')  || 0,\n    motion: global.get('last_motion') || false,\n    dist:   global.get('last_dist')   || 0\n};\nlog.push(entry);\nlog = log.filter(function(r){ return r.ts > Date.now() - 86400000; });\nglobal.set('sensor_log', log);\n\nvar row = entry.time+','+entry.temp+','+entry.hum+','+entry.light+','+entry.motion+','+entry.dist+'\\n';\nif (isNew) {\n    msg.payload  = 'Timestamp,Temp_C,Humidity_pct,Light_raw,Motion,Distance_cm\\n' + row;\n    msg.overwrite = true;\n} else {\n    msg.payload   = row;\n    msg.overwrite = false;\n}\nreturn msg;",
        "outputs": 1,
        "x": 320,
        "y": 1500,
        "wires": [
            [
                "fn_csv_route"
            ]
