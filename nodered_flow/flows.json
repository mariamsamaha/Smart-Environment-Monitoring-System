        "func": "global.set('last_motion', msg.payload.detected);\nif (msg.payload.detected) {\n    msg.payload = '🚨 Motion Detected';\n    var alert = {payload: '🚨 MOTION DETECTED', topic: new Date().toLocaleTimeString()};\n    node.send([msg, alert, alert]);\n} else {\n    msg.payload = '✅ No Motion';\n    node.send([msg, null, null]);\n}",
