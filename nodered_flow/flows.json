    {
        "id": "fn_data_log",
        "type": "function",
        "z": "da2297979f2a7d69",
        "name": "Append to Log",
        "func": "var log = global.get('sensor_log') || [];\nlog.push({\n    ts:     Date.now(),\n    time:   new Date().toISOString(),\n    temp:   global.get('last_temp')   || 0,\n    hum:    global.get('last_hum')    || 0,\n    light:  global.get('last_light')  || 0,\n    motion: global.get('last_motion') || false,\n    dist:   global.get('last_dist')   || 0\n});\nvar cutoff = Date.now() - 86400000;\nlog = log.filter(function(r){ return r.ts > cutoff; });\nglobal.set('sensor_log', log);\nreturn null;",
        "outputs": 1,
        "x": 510,
        "y": 1760,
        "wires": [
            []
        ]
