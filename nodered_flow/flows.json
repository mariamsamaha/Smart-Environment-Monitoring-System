    {
        "id": "fn_log_alert",
        "type": "function",
        "z": "flow1",
        "name": "Log Alert",
        "func": "var log = global.get('alert_log') || [];\nlog.unshift({Time: msg.topic || new Date().toLocaleTimeString(), Message: msg.payload});\nif (log.length > 50) log = log.slice(0, 50);\nglobal.set('alert_log', log);\nmsg.payload = log;\nreturn msg;",
