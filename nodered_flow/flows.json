    {
        "id": "fn_watchdog_check",
        "type": "function",
        "z": "da2297979f2a7d69",
        "name": "Watchdog Check",
        "func": "var last = flow.get('last_heartbeat') || 0;\nvar diff = Date.now() - last;\nif (last === 0) {\n    msg.payload = '⏳ Waiting for ESP32...';\n} else if (diff > 30000) {\n    msg.payload = '❌ ESP32 OFFLINE — No heartbeat for ' + Math.round(diff/1000) + 's';\n} else {\n    msg.payload = '✅ ESP32 Online — Last seen ' + Math.round(diff/1000) + 's ago';\n}\nreturn msg;",
        "outputs": 1,
        "x": 530,
        "y": 1640,
        "wires": [
