    {
        "id": "fn_telegram",
        "type": "function",
        "z": "flow1",
        "name": "Telegram Notify",
        "func": "var token  = (global.get('tg_token') || '').trim();\nvar chatId = (global.get('tg_chat')  || '').trim();\nif (!token || !chatId) return null;\n\n// 60-second cooldown per alert type\nvar key  = 'tg_cd_' + msg.payload.replace(/[^A-Z]/g,'').substring(0,12);\nvar last = global.get(key) || 0;\nif (Date.now() - last < 60000) return null;\nglobal.set(key, Date.now());\n\nmsg.url     = 'https://api.telegram.org/bot' + token + '/sendMessage';\nmsg.method  = 'POST';\nmsg.headers = {'Content-Type':'application/json'};\nmsg.payload = JSON.stringify({\n    chat_id: chatId,\n    text: 'SmartEnv Alert\n' + msg.payload + '\n' + new Date().toLocaleTimeString()\n});\nreturn msg;",
        "outputs": 1,
        "x": 1000,
        "y": 380,
        "wires": [
            [
                "http_telegram"
            ]
        ]
    },
    {
        "id": "fn_telegram_test",
        "type": "function",
        "z": "flow1",
        "name": "Telegram Test",
        "func": "var token  = (global.get('tg_token') || '').trim();\nvar chatId = (global.get('tg_chat')  || '').trim();\nif (!token || !chatId) {\n    node.warn('Set Bot Token and Chat ID first');\n    return null;\n}\nmsg.url     = 'https://api.telegram.org/bot' + token + '/sendMessage';\nmsg.method  = 'POST';\nmsg.headers = {'Content-Type':'application/json'};\nmsg.payload = JSON.stringify({\n    chat_id: chatId,\n    text: 'SmartEnv Test\nTelegram is working!\n' + new Date().toLocaleTimeString()\n});\nreturn msg;",
        "outputs": 1,
        "x": 500,
        "y": 900,
        "wires": [
            []
        ]
