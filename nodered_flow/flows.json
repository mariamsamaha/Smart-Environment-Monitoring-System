    {
        "id": "fn_history",
        "type": "function",
        "z": "flow1",
        "name": "Filter History",
        "func": "var hours  = parseInt(msg.payload) || 1;\nvar cutoff = Date.now() - hours * 3600000;\nvar log    = global.get('sensor_log') || [];\nvar rows   = log.filter(function(r){ return r.ts >= cutoff; });\n// Clear chart first\nnode.send({payload:[], topic:'Temperature'});\nnode.send({payload:[], topic:'Humidity'});\n// Send each point\nrows.forEach(function(r){\n    node.send({payload: r.temp, topic:'Temperature', x: r.ts});\n});\nrows.forEach(function(r){\n    node.send({payload: r.hum,  topic:'Humidity',    x: r.ts});\n});\nreturn null;",
        "outputs": 1,
        "x": 360,
        "y": 1780,
        "wires": [
