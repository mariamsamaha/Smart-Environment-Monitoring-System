    {
        "id": "fn_csv_dl",
        "type": "function",
        "z": "flow1",
        "name": "Build CSV Download",
        "func": "var hours  = parseInt(msg.req.query.hours) || 24;\nvar cutoff = Date.now() - hours * 3600000;\nvar log    = global.get('sensor_log') || [];\nvar rows   = log.filter(function(r){ return r.ts >= cutoff; });\nvar csv    = 'Timestamp,Temp_C,Humidity_pct,Light_raw,Motion,Distance_cm\\n';\nrows.forEach(function(r){\n    csv += r.time+','+r.temp+','+r.hum+','+r.light+','+r.motion+','+r.dist+'\\n';\n});\nmsg.payload = csv;\nmsg.headers = {\n    'Content-Type': 'text/csv',\n    'Content-Disposition': 'attachment; filename=\"smartenv_'+hours+'h.csv\"'\n};\nreturn msg;",
        "outputs": 1,
        "x": 340,
        "y": 1620,
        "wires": [
            [
                "http_out"
            ]
        ]
